          </property>
         </widget>
        </item>
        <item>
         <widget class="QComboBox" name="nodeFieldCombo"/>
        </item>
       </layout>
      </item>

    <!-- Fix NodeID to all polygons -->
      <item>
       <widget class="QRadioButton" name="nodeSameRadio">
        <property name="text">
         <string>Assign same NodeID to all polygons</string>
