        </item>
        <item>
         <widget class="QLineEdit" name="nodeSameLineEdit">
          <property name="placeholderText">
           <string>e.g. NODE_001</string>
          </property>
          <property name="enabled">
           <bool>false</bool>
          </property>
         </widget>
        </item>
       </layout>
      </item>


